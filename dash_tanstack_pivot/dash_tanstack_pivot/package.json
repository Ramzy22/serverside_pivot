{
  "name": "dash_tanstack_pivot",
  "version": "0.0.43",
  "description": "A Dash component built with TanStack Table v8",
  "main": "build/index.js",
  "scripts": {
    "start": "webpack-dev-server --config ./webpack.serve.config.js --open",
    "build:js": "webpack --mode production",
